{
  "name": "@midnight-ntwrk/contract",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./dist/index.browser.js": {
      "types": "./dist/index.browser.d.ts",
      "import": "./dist/index.browser.js",
      "default": "./dist/index.browser.js"
    },
    "./dist/managed/PrivaMedAI/contract/index.js": {
      "types": "./dist/managed/PrivaMedAI/contract/index.d.ts",
      "import": "./dist/managed/PrivaMedAI/contract/index.js",
      "default": "./dist/managed/PrivaMedAI/contract/index.js"
    },
    "./dist/managed/*": {
      "types": "./dist/managed/*",
      "import": "./dist/managed/*",
      "default": "./dist/managed/*"
    }
  },
  "scripts": {
    "compact": "rm -rf src/managed/* && name=$(basename $(ls src/*.compact) .compact) && compactc src/$name.compact src/managed/$name",
    "build": "rm -rf dist && mkdir -p dist && cp -Rf ./src/managed ./dist/managed && cp ./src/*.compact ./dist",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "npm run compact && npm run build",
    "test": "vitest run src/test"
  }
}
