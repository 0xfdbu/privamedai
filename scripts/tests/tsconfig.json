{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": "../..",
    "paths": {
      "@midnight-ntwrk/*": ["node_modules/@midnight-ntwrk/*"]
    }
  },
  "include": ["./*.ts"],
  "exclude": ["node_modules"]
}
