{
  "name": "priva-cred",
  "description": "Privacy-first verifiable credentials dApp on Midnight Network",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "contract",
    "api",
    "frontend",
    "boilerplate/contract-cli",
    "boilerplate/scripts"
  ],
  "scripts": {
    "dev": "export PATH=\"$HOME/.compact/versions/0.30.0/x86_64-unknown-linux-musl:$PATH\" && rm -rf contract/src/managed/* && node boilerplate/scripts/auto-generator.js",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:integration": "vitest run tests/integration-tests.ts",
    "test:integration:watch": "vitest tests/integration-tests.ts",
    "wallet": "node boilerplate/scripts/generate-key.js",
    "faucet": "node boilerplate/scripts/request-faucet.js",
    "balance": "node boilerplate/scripts/check-balance.js",
    "deploy": "npx tsx scripts/deploy-preprod.ts",
    "deploy:preprod": "npx tsx scripts/deploy-preprod.ts",
    "deploy:privamedai": "npx tsx scripts/deploy-privamedai.ts",
    "deploy:with-wallet": "npx tsx deploy-with-wallet.ts",
    "deploy:legacy": "node boilerplate/scripts/deploy.js --new",
    "cli": "npx tsx scripts/cli-preprod.ts",
    "cli:privamedai": "npx tsx scripts/cli-privamedai.ts",
    "test:privamedai:txs": "npx tsx scripts/test-privamedai-txs.ts",
    "test:all-features": "npx tsx scripts/test-all-features.ts",
    "check": "node -e \"console.log('✅ PrivaCred is ready!'); console.log('💡 Run npm run dev to compile contract'); process.exit(0)\""
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@midnight-ntwrk/ledger-v8": "^8.0.3",
    "@midnight-ntwrk/wallet-sdk-dust-wallet": "^3.0.0",
    "@midnight-ntwrk/wallet-sdk-facade": "^3.0.0",
    "@midnight-ntwrk/wallet-sdk-hd": "^3.0.1",
    "@midnight-ntwrk/wallet-sdk-shielded": "^2.1.0",
    "@midnight-ntwrk/wallet-sdk-unshielded-wallet": "^2.1.0",
    "@scure/bip39": "^2.0.1",
    "@types/node": "^22.15.29",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.33.1",
    "@typescript-eslint/parser": "^8.33.1",
    "cors-anywhere": "^0.4.4",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.1",
    "rxjs": "^7.8.2",
    "testcontainers": "^11.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "vitest": "^3.2.0",
    "ws": "^8.20.0"
  },
  "dependencies": {
    "@midnight-ntwrk/compact-js": "^2.5.0",
    "@midnight-ntwrk/compact-runtime": "^0.15.0",
    "@midnight-ntwrk/midnight-js": "^4.0.4",
    "@midnight-ntwrk/midnight-js-contracts": "^4.0.2",
    "@midnight-ntwrk/midnight-js-fetch-zk-config-provider": "^4.0.2",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "^4.0.2",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "^4.0.2",
    "@midnight-ntwrk/midnight-js-level-private-state-provider": "^4.0.2",
    "@midnight-ntwrk/midnight-js-network-id": "^4.0.4",
    "@midnight-ntwrk/midnight-js-node-zk-config-provider": "^4.0.2",
    "@midnight-ntwrk/midnight-js-types": "^4.0.2",
    "@midnight-ntwrk/midnight-js-utils": "^4.0.2",
    "@midnight-ntwrk/wallet": "^5.0.0",
    "@midnight-ntwrk/wallet-api": "^5.0.0",
    "@midnight-ntwrk/wallet-sdk-address-format": "^3.1.0",
    "@midnight-ntwrk/zswap": "^4.0.0",
    "bip39": "^3.1.0",
    "dotenv": "^16.5.0",
    "node-fetch": "^3.3.2",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "tweetnacl": "^1.0.3"
  },
  "overrides": {
    "@midnight-ntwrk/midnight-js-network-id": "^4.0.4"
  }
}
